# =============================================================================
# Kitchen Portfolio — Shared Environment Configuration
# =============================================================================
# Copy this file to `.env` and adjust values. ONE shared .env feeds frontend,
# backend, Caddy, and docker-compose.
# =============================================================================

# -- Environment ------------------------------------------------------------- #
APP_ENV=development                # development | production
APP_NAME="Woodmore Kitchens"
APP_DOMAIN=localhost
APP_TIMEZONE=America/Los_Angeles

# -- Backend (FastAPI) ------------------------------------------------------- #
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_INTERNAL_PORT=8000
BACKEND_WORKERS=2
BACKEND_LOG_LEVEL=info
SECRET_KEY=change-me-in-production-please-generate-a-long-random-string
CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:8080

# -- Frontend (React + Vite) ------------------------------------------------- #
FRONTEND_PORT=5173
FRONTEND_INTERNAL_PORT=5173
VITE_API_BASE_URL=/api/v1
VITE_PHOTOS_BASE_URL=/photos
VITE_SITE_NAME="Woodmore Kitchens"
VITE_SITE_DESCRIPTION="Bespoke custom kitchen cabinets, crafted to last a lifetime."

# -- Caddy (reverse proxy) --------------------------------------------------- #
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443
CADDY_DOMAIN=localhost

# -- Database (PostgreSQL) --------------------------------------------------- #
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=kitchen
POSTGRES_PASSWORD=kitchen_secret_change_me
POSTGRES_DB=kitchen_portfolio
DATABASE_URL=postgresql+psycopg://kitchen:kitchen_secret_change_me@db:5432/kitchen_portfolio

# -- Paths ------------------------------------------------------------------- #
PHOTOS_DIR=/photos                 # absolute path inside the container
